{
  "schemaVersion": 1,
  "name": "Ultimate Client",
  "id": "ultimate-client",
  "version": "${version}",
  "description": "Based utility mod.",
  "authors": [
    "Banicoder77"
  ],
  "contact": {
    "homepage": "https://meteorclient.com",
    "issues": "https://github.com/UltimateDevelopment/ultimate-client/issues",
    "sources": "https://github.com/UltimateDevelopment/ultimate-client",
    "discord": "https://meteorclient.com/discord"
  },
  "license": "GPL-3.0",
  "icon": "assets/ultimate-client/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "ultimatedevelopment.ultimateclient.UltimateClient"
    ],
    "modmenu": [
      "ultimatedevelopment.ultimateclient.modintegration.ModMenuIntegration"
    ]
  },
  "mixins": [
    "ultimate-client.mixins.json",
    "ultimate-client-baritone.mixins.json",
    "ultimate-client-indigo.mixins.json",
    "ultimate-client-sodium.mixins.json",
    "ultimate-client-lithium.mixins.json",
    "ultimate-client-viafabricplus.mixins.json"
  ],
  "accessWidener": "ultimate-client.accesswidener",
  "custom": {
    "ultimate-client:build_number": "${build_number}",
    "ultimate-client:color": "145,61,226",
    "ultimate-client:commit": "${commit}",
    "modmenu": {
      "links": {
        "modmenu.discord": "https://meteorclient.com/discord"
      }
    },
    "badoptimizations:cache_hooks": {
      "lightmap": "ultimatedevelopment.ultimateclient.modintegration.BadOptimizationsHook"
    }
  },
  "depends": {
    "java": ">=21",
    "minecraft": ["${minecraft_version}"],
    "fabricloader": ">=${loader_version}"
  },
  "breaks": {
    "optifabric": "*",
    "feather": "*",
    "origins": "*",
    "sodium": "<0.8.7",
    "morechathistory": "*",
    "lithium": "<0.21.3"
  }
}
